# Environment Configuration Example
# Copy this file to .env and update with your values

# Node Environment
NODE_ENV=production

# Database Configuration
POSTGRES_DB=auth_app_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Application Ports
BACKEND_PORT=3000
FRONTEND_PORT=80

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL
FRONTEND_URL=http://localhost

# Encryption Key for API Keys Storage (must be at least 32 characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate-a-secure-key-here

# Comma-separated outbound server IPs that users must whitelist on their exchange API keys
WHITELIST_IPS=

# NOWPayments Billing (required for /api/billing/* endpoints)
# Sign up at https://nowpayments.io to get your keys
# Set to 'true' for sandbox testing (uses api-sandbox.nowpayments.io)
NOWPAYMENTS_SANDBOX=false
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Public backend URL (used for NOWPayments IPN webhook callback)
# Must be publicly reachable by NOWPayments servers
# For local dev: use ngrok URL so NOWPayments IPN webhook can reach you
PUBLIC_BACKEND_URL=http://localhost:3000

# Bybit API Configuration (Optional)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# BingX API Configuration (Optional)
BINGX_API_KEY=
BINGX_API_SECRET=

# Binance API Configuration (Optional)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Gate.io API Configuration (Optional)
GATEIO_API_KEY=
GATEIO_API_SECRET=
